import tkinter as tk
from tkinter import messagebox, ttk
import json
import os
from datetime import datetime

# -----------------------------
# File for saving
# -----------------------------
DATA_FILE = "tasks.json"

# -----------------------------
# Data storage (list of dicts = simpler + less bugs)
# -----------------------------
tasks = []

# -----------------------------
# Save / Load
# -----------------------------
def save_tasks():
    with open(DATA_FILE, "w") as f:
        json.dump(tasks, f, indent=4)


def load_tasks():
    if os.path.exists(DATA_FILE):
        try:
            with open(DATA_FILE, "r") as f:
                data = json.load(f)
                if isinstance(data, list):
                    tasks.extend(data)
        except:
            pass

# -----------------------------
# UI Functions
# -----------------------------
def refresh_list():
    listbox.delete(0, tk.END)

    done_count = 0

    for i, t in enumerate(tasks):
        status = "Done" if t["done"] else "Not done"
        if t["done"]:
            done_count += 1

        work_type = t.get("work_type", "Individual")
        priority = t.get("priority", "Medium")

        listbox.insert(
            tk.END,
            f"{i+1}. {t['task']} | {t['subject']} | {t['deadline']} | {t['type']} | {priority} | {work_type} | {status}"
        )

    total = len(tasks)
    progress_label.config(text=f"Progress: {done_count} / {total} Tasks Done")

    if total > 0:
        progress['value'] = (done_count / total) * 100
    else:
        progress['value'] = 0


def add_task():
    task = entry_task.get().strip()
    subject = entry_subject.get().strip()
    deadline = entry_deadline.get().strip()
    task_type = combo_type.get()
    topic = entry_topics.get().strip()
    work_type = work_combo.get()
    priority = priority_combo.get()
    notes = notes_text.get("1.0", tk.END).strip()

    if not task or not subject or not deadline:
        messagebox.showwarning("Error", "Please fill all required fields!")
        return

    try:
        datetime.strptime(deadline, "%Y-%m-%d %H:%M")
    except ValueError:
        messagebox.showwarning("Error", "Deadline must be in YYYY-MM-DD HH:MM format")
        return

    tasks.append({
        "task": task,
        "subject": subject,
        "deadline": deadline,
        "type": task_type,
        "topics": topic,
        "work_type": work_type,
        "priority": priority,
        "notes": notes,
        "done": False
    })

    save_tasks()
    refresh_list()

    entry_task.delete(0, tk.END)
    entry_subject.delete(0, tk.END)
    entry_deadline.delete(0, tk.END)
    entry_topics.delete(0, tk.END)
    notes_text.delete("1.0", tk.END)
    priority_combo.set("Medium")


def mark_done():
    try:
        index = listbox.curselection()[0]
        tasks[index]["done"] = True
        save_tasks()
        refresh_list()
    except:
        messagebox.showwarning("Error", "Select a task first!")


def delete_task():
    try:
        index = listbox.curselection()[0]
        confirm = messagebox.askyesno("Confirm", "Delete this task?")
        if confirm:
            tasks.pop(index)
            save_tasks()
            refresh_list()
    except:
        messagebox.showwarning("Error", "Select a task first!")


open_detail_windows = {}
MAX_OPEN_WINDOWS = 5

def show_details(event):
    selected = listbox.curselection()

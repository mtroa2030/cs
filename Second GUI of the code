        return

    index = selected[0]
    t = tasks[index]

    task_key = f"{t['task']}_{t['deadline']}"

    if task_key in open_detail_windows:
        existing_window = open_detail_windows[task_key]

        try:
            existing_window.lift()
            existing_window.focus_force()
            return
        except:
            del open_detail_windows[task_key]
    
